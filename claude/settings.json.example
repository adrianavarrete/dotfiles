{
  "permissions": {
    "allow": [
      "Read(*)",
      "Bash(tree:*)",
      "Bash(docker:*)",
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(which*)",
      "Bash(cat package.json)",
      "Bash(find *)",
      "Bash(sed *)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets.*)",
      "Read(**/.secrets.*)",
      "Read(**/secret.*)",
      "Read(**/.secret.*)",
      "Read(**/password*)",
      "Read(**/credentials.*)",
      "Read(**/.credentials.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa)",
      "Read(**/id_rsa.*)",
      "Read(**/.aws/*)",
      "Read(**/.ssh/*)",
      "Read(**/*_token)",
      "Read(**/*.token)",
      "Read(**/token.json)",
      "Read(**/tokens.json)",
      "Read(**/*_token*)",
      "Read(**/*.pfx)"
    ],
    "ask": [
      "Bash(git reset*)",
      "Bash(git push*)",
      "Bash(git clean -f*)",
      "Bash(git checkout .*)",
      "Bash(git restore .*)",
      "Bash(git branch -D*)",
      "Bash(git filter-branch*)",
      "Bash(git rebase*)",
      "Bash(rm -rf*)",
      "Bash(docker system prune*)",
      "Bash(npm publish*)",
      "Bash(echo $*)",
      "Bash(*password*)",
      "Bash(*secret*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify-sound.sh stop"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify-sound.sh notification"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true
  },
  "effortLevel": "medium"
}
